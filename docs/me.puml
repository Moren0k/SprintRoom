@startuml SprintRoom_Arquitectura_Completa
title SprintRoom — Vista General Completa del Sistema Actual

left to right direction
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam packageStyle rectangle
skinparam componentStyle rectangle
skinparam linetype ortho
skinparam roundcorner 12
skinparam defaultFontName Arial
skinparam defaultFontSize 12

skinparam rectangle {
  BorderColor #444444
  BackgroundColor #FAFAFA
}

skinparam package {
  BorderColor #333333
  BackgroundColor #F7F7F7
}

skinparam database {
  BorderColor #333333
  BackgroundColor #FFF8E1
}

skinparam actor {
  BorderColor #333333
  BackgroundColor #FFFFFF
}

skinparam note {
  BorderColor #A66A00
  BackgroundColor #FFF3CD
}

legend right
  |= Color / línea |= Significado |
  | Verde | Flujo principal correcto |
  | Rojo | Bypass / riesgo actual |
  | Azul | Integración externa |
  | Morado | IA / MCP / agentes |
  | Gris | Documentación, tests, tooling |
endlegend

' ============================================================
' ACTORES / CONSUMIDORES
' ============================================================

actor "Usuario final\nDueño / miembro de proyecto" as User
actor "Super Admin" as SuperAdmin
actor "Agente IA\nOpenCode / Claude / Cursor" as AIAgent
actor "Desarrollador" as Developer

cloud "OpenRouter / OpenAI API\nProveedor LLM" as OpenRouter #EDE7F6
cloud "InsForge Auth\nOAuth / Password / Tokens" as InsForgeAuth #E3F2FD
cloud "InsForge Platform\nPostgREST / Storage / Realtime / Functions" as InsForgePlatform #E3F2FD

' ============================================================
' REPOSITORIO
' ============================================================

rectangle "Repositorio SprintRoom\nNext.js + TypeScript + InsForge + MCP" as Repo {

  ' ------------------------------------------------------------
  ' FRONTEND / NEXT APP ROUTER
  ' ------------------------------------------------------------

  package "app/ — Next.js App Router" as NextApp #E8F5E9 {

    package "Rutas públicas" as PublicRoutes {
      component "app/page.tsx\nLanding pública" as Landing
      component "components/demo-board.tsx\nDemo board mock" as DemoBoard
      component "components/chatbot.tsx\nChatbot público" as PublicChatbot
      component "app/api/chat/route.ts\nAPI Chat público" as ChatApi
    }

    package "Auth UI" as AuthUI {
      component "app/(auth)/login/page.tsx" as LoginPage
      component "app/(auth)/register/page.tsx" as RegisterPage
      component "components/auth-forms.tsx" as AuthForms
    }

    package "App protegida — app/(app)" as ProtectedApp {
      component "app/(app)/layout.tsx\nProtectedLayout" as ProtectedLayout
      component "components/app-shell.tsx\nShell principal" as AppShell

      component "app/(app)/dashboard/page.tsx\nDashboard" as DashboardPage
      component "components/dashboard-client.tsx" as DashboardClient

      component "app/(app)/projects/page.tsx\nProyectos" as ProjectsPage
      component "components/projects-client.tsx" as ProjectsClient

      component "app/(app)/projects/[projectId]/page.tsx\nDetalle proyecto" as ProjectDetailPage
      component "components/project-detail-client.tsx" as ProjectDetailClient

      component "app/(app)/projects/[projectId]/stories/[userStoryId]/page.tsx\nTareas por historia" as StoryTasksPage
      component "components/story-tasks-client.tsx" as StoryTasksClient

      component "app/(app)/tasks/page.tsx\nTareas globales" as TasksPage
      component "components/tasks-client.tsx" as TasksClient

      component "app/(app)/account/page.tsx\nCuenta" as AccountPage
      component "components/account-client.tsx" as AccountClient

      component "app/(app)/docs/page.tsx\nDocs UI" as DocsPage
      component "components/docs-client.tsx" as DocsClient

      component "app/(app)/imagine/page.tsx\nImagine / IA para planear proyecto" as ImaginePage
      component "components/imagine-client.tsx" as ImagineClient
    }

    package "Frontend compartido" as FrontendShared {
      component "src/frontend/api-client.ts\nCliente HTTP interno" as ApiClient
      component "src/frontend/session-context.tsx\nSession Provider" as SessionContext
      component "src/frontend/types.ts\nTipos frontend\nDuplicados parcialmente" as FrontendTypes #FFF3CD
      component "components/ui.tsx\nUI primitives" as UIPrimitives
      component "app/globals.css\nTailwind / estilos globales" as GlobalCSS
    }
  }

  ' ------------------------------------------------------------
  ' API ROUTES
  ' ------------------------------------------------------------

  package "app/api/** — Adaptadores HTTP" as ApiRoutes #E3F2FD {

    package "Auth API" as AuthApi {
      component "POST /api/auth/register\napp/api/auth/register/route.ts" as RegisterApi #FFF3CD
      component "POST /api/auth/login\napp/api/auth/login/route.ts" as LoginApi #FFF3CD
      component "POST /api/auth/logout\napp/api/auth/logout/route.ts" as LogoutApi
      component "GET /api/auth/callback\nOAuth callback" as OAuthCallback #FFF3CD
    }

    package "Account / Admin" as AccountApi {
      component "GET/PATCH /api/account" as AccountRoute
      component "POST /api/admin/users" as AdminUsersRoute
    }

    package "Projects API" as ProjectsApi {
      component "GET/POST /api/projects" as ProjectsRoute
      component "GET/PATCH/DELETE\n/api/projects/[projectId]" as ProjectByIdRoute
      component "GET/POST\n/api/projects/[projectId]/members" as ProjectMembersRoute
      component "DELETE\n/api/projects/[projectId]/members/[userId]" as ProjectMemberByIdRoute
      component "GET/POST\n/api/projects/[projectId]/user-stories" as ProjectStoriesRoute
      component "GET/POST\n/api/projects/[projectId]/mcp-keys" as McpKeysRoute #FFEBEE
      component "DELETE\n/api/projects/[projectId]/mcp-keys/[keyId]" as McpKeyByIdRoute #FFEBEE
    }

    package "Tasks / User Stories API" as WorkApi {
      component "GET /api/tasks\nPOST /api/tasks" as TasksRoute
      component "GET/PATCH/DELETE\n/api/tasks/[sprintTaskId]" as TaskByIdRoute
      component "POST\n/api/tasks/[sprintTaskId]/comments" as TaskCommentsRoute
      component "GET/PATCH/DELETE\n/api/user-stories/[userStoryId]" as UserStoryByIdRoute
    }

    package "Imagine / IA API" as ImagineApi {
      component "POST /api/imagine/chat\nLLM conversa con usuario" as ImagineChatRoute #EDE7F6
      component "POST /api/imagine/compile\nLLM genera JSON plan" as ImagineCompileRoute #EDE7F6
      component "POST /api/imagine/plan\nPersistir plan generado" as ImaginePlanRoute
    }

    package "MCP API" as McpApi #F3E5F5 {
      component "GET/POST /api/mcp\nJSON-RPC 2.0 + HTTP simple" as McpRoute #FFEBEE
    }
  }

  ' ------------------------------------------------------------
  ' SERVER SUPPORT
  ' ------------------------------------------------------------

  package "src/server — Soporte HTTP / composición" as ServerLayer #E3F2FD {
    component "application-scope.ts\ncreateApplicationScope()\ncreateAuthenticatedApplicationScope()" as ApplicationScope
    component "http.ts\nok / created / readJsonObject /\nhandleRouteError" as HttpHelpers
    component "validation.ts\nparse / requireString /\nparseStatus / roles" as ServerValidation
  }

  ' ------------------------------------------------------------
  ' APPLICATION LAYER
  ' ------------------------------------------------------------

  package "src/application — Casos de uso / Application Layer" as ApplicationLayer #E8F5E9 {

    package "Abstractions" as AppAbstractions {
      interface "ports.ts\nRepositories / UnitOfWork / Clock / Hasher" as Ports
      component "application-error.ts\nErrores tipados" as AppErrors
      component "request-context.ts\nUsuario actual / contexto" as RequestContext
      component "messages.ts" as Messages
    }

    package "Features / Use Cases" as UseCases {
      component "accounts.ts\nGet/Update profile\nCreate admin user" as AccountsUseCases
      component "projects.ts\nList/Create/Get/Update project" as ProjectsUseCases
      component "project-access.ts\nProjectAccess" as ProjectAccessUseCase
      component "members.ts\nAdd/List/Remove members" as MembersUseCases
      component "user-stories.ts\nCRUD historias" as UserStoriesUseCases
      component "tasks.ts\nCRUD tareas\nstatus/comments/detail" as TasksUseCases
      component "deletion.ts\nBorrado con confirmación" as DeletionUseCases
      component "imagine.ts\nPlanProjectFromIdeaHandler" as ImagineUseCases
    }

    package "DTOs / Application models" as AppModels {
      component "application-dtos.ts\nDTOs compartidos parcialmente" as ApplicationDtos #FFF3CD
      component "index.ts\nExports application" as ApplicationIndex
    }
  }

  ' ------------------------------------------------------------
  ' DOMAIN LAYER
  ' ------------------------------------------------------------

  package "src/domain — Dominio / Reglas de negocio" as DomainLayer #E0F2F1 {

    package "Aggregates" as Aggregates {
      class "User\nsrc/domain/aggregates/user.ts" as AggUser
      class "Project\nsrc/domain/aggregates/project.ts" as AggProject
      class "UserStory\nsrc/domain/aggregates/user-story.ts" as AggUserStory
      class "SprintTask\nsrc/domain/aggregates/sprint-task.ts" as AggSprintTask
    }

    package "Entities" as Entities {
      class "ProjectMember\nsrc/domain/entities/project-member.ts" as EntProjectMember
      class "TaskComment\nsrc/domain/entities/task-comment.ts" as EntTaskComment
    }

    package "Value Objects" as ValueObjects {
      class "EmailAddress" as VOEmail
      class "PersonName" as VOPersonName
      class "ProjectName" as VOProjectName
      class "WorkItemName" as VOWorkItemName
      class "Description" as VODescription
      class "ExternalReference" as VOExternalRef
      class "CommentBody" as VOCommentBody
    }

    package "Policies / Services" as DomainPolicies {
      component "AuthorizationPolicy\nroles/permisos" as AuthorizationPolicy
      component "VisibilityPolicy\nvisibilidad por rol" as VisibilityPolicy
      component "AuditPolicy" as AuditPolicy
      component "DeletionGuard" as DeletionGuard
      component "DeletionConfirmationPolicy\nconfirmación exacta" as DeletionConfirmation
      component "ProjectProgressCalculator" as ProgressCalculator
    }

    package "Enums" as DomainEnums {
      enum "SystemRole" as SystemRole {
        user
        super_admin
      }

      enum "ProjectRole" as ProjectRole {
        viewer
        member
        admin
        owner
      }

      enum "TaskStatus" as TaskStatus {
        not_started
        in_progress
        testing
        review
        completed
      }

      enum "PermissionAction" as PermissionAction
      enum "AccountOrigin" as AccountOrigin
    }

    package "Domain Events / IDs" as DomainEvents {
      component "ProjectCreatedDomainEvent" as ProjectCreatedEvent
      component "TaskCommentAddedDomainEvent" as TaskCommentEvent
      component "UserRegisteredDomainEvent" as UserRegisteredEvent

      component "UserId / ProjectId /\nUserStoryId / SprintTaskId /\nTaskCommentId" as DomainIds
      component "IdFactory" as IdFactory
    }
  }

  ' ------------------------------------------------------------
  ' INFRASTRUCTURE
  ' ------------------------------------------------------------

  package "src/lib — Infraestructura / Adaptadores" as InfraLayer #FFF8E1 {

    package "InsForge Adapter" as InsForgeAdapter {
      component "src/lib/insforge/client.ts\nCliente InsForge API key" as InsForgeClient
      component "src/lib/insforge/database-gateway.ts\nGateway DB" as DatabaseGateway
      component "src/lib/insforge/repositories.ts\nRepositories" as Repositories
      component "src/lib/insforge/unit-of-work.ts\nUnitOfWork\nNO transacciones reales" as UnitOfWork #FFEBEE
      component "src/lib/insforge/mappers.ts\nMappers DB <-> Domain" as Mappers
      component "src/lib/insforge/schema.ts\nTipos de tablas" as InsForgeSchema
      component "src/lib/insforge/errors.ts" as InsForgeErrors
      component "src/lib/insforge-server.ts\nCliente auth por sesión/token" as InsForgeServerClient
    }

    package "Auth / Session" as AuthInfra {
      component "src/lib/auth/request-auth.ts\nResolver sesión desde request" as RequestAuth
      component "src/lib/auth/session-token.ts\nSession token" as SessionToken
      component "src/lib/auth/password-hasher.ts\nPBKDF2 hash" as PasswordHasher
      component "src/lib/auth/oauth-actions.ts\nServer Action OAuth" as OAuthActions #FFF3CD
      component "src/lib/insforge-cookies.ts\nCookies HttpOnly" as InsForgeCookies
    }

    package "Audit / Observability" as AuditInfra {
      component "src/lib/audit/audit-logger.ts\nAudit logger" as AuditLogger
      component "console.error en IA routes\nLogging básico" as BasicLogging #FFF3CD
    }

    package "Read Models" as ReadModels {
      component "src/lib/read-models/dashboard.ts\nCQRS-lite Dashboard" as DashboardReadModel
    }

    package "System" as SystemInfra {
      component "src/lib/env.ts\nVariables entorno" as EnvConfig
      component "src/lib/system-clock.ts\nClock" as SystemClock
    }
  }

  ' ------------------------------------------------------------
  ' MCP INTERNO
  ' ------------------------------------------------------------

  package "src/lib/mcp — MCP interno" as McpInternal #F3E5F5 {
    component "auth.ts\nresolveProjectKey()\nSHA-256 PROJECT_KEY" as McpAuth
    component "tools.ts\nMCP_TOOL_DEFINITIONS\nparseToolArgs()" as McpTools
    component "types.ts\nMCP types" as McpTypes
    component "service.ts\nMcpService\nconsulta/escribe DB directo" as McpService #FFEBEE
    component "skill.ts\ngetSprintroomMcpSkillPackage()" as McpSkillRuntime
  }

  package "packages/sprintroom-mcp — Paquete MCP público" as McpPackage #F3E5F5 {
    component "packages/sprintroom-mcp/src/index.ts\nCLI/adapter público MCP" as McpPkgIndex
    component "packages/sprintroom-mcp/README.md" as McpPkgReadme
    component "packages/sprintroom-mcp/RELEASE_NOTES.md" as McpReleaseNotes
    component "packages/sprintroom-mcp/dist/index.js\nBuild distribuible" as McpDist
  }

  package "scripts — Pruebas / MCP stdio" as Scripts {
    component "scripts/mcp-server.ts\nServidor stdio local" as McpStdioServer
    component "scripts/smoke-test-mcp.ts" as SmokeMcp
    component "scripts/smoke-test-mcp-full.ts" as SmokeMcpFull
  }

  ' ------------------------------------------------------------
  ' DOCUMENTACIÓN / SKILLS / AGENTES
  ' ------------------------------------------------------------

  package "Documentación / Skills / Reglas de agentes" as DocsAndSkills #EEEEEE {
    component "README.md\nDescripción general" as Readme
    component "AGENTS.md\nReglas para agentes" as AgentsMd
    component "CLAUDE.md\nReglas/contexto Claude" as ClaudeMd
    component ".sprintroom/sprintroom-mcp/README.md\nSkill instalada" as SkillReadme
    component ".sprintroom/sprintroom-mcp/SKILL.md\nSkill oficial MCP" as SkillMd

    component "docs/architecture-audit.md\nAuditoría arquitectónica" as ArchitectureAudit
    component "docs/sprintroom_business_logic.md\nReglas negocio" as BusinessDocs
    component "docs/sprintroom_domain_decisions.md\nDecisiones dominio" as DomainDocs
    component "docs/sprintroom_infrastructure_notes.md\nNotas infraestructura" as InfraDocs
    component "docs/mcp-agent-usage.md\nUso MCP por agentes" as McpUsageDocs
    component "docs/mcp-kanban-scrum-integration.md\nMCP + Kanban/Scrum" as McpScrumDocs
    component "docs/security-project-key-isolation.md\nAislamiento PROJECT_KEY" as SecurityDocs
    component "docs/frontend-project-navigation.md\nNavegación frontend" as FrontendNavDocs
    component "docs/chatbot-knowledge-base.md\nBase conocimiento chatbot" as ChatbotDocs
  }

  ' ------------------------------------------------------------
  ' TESTS / CI / TOOLING
  ' ------------------------------------------------------------

  package "Calidad / Tests / CI" as Quality #EEEEEE {
    component ".github/workflows/ci.yml\nTypecheck + Lint + Test + Build\nMCP package verify" as CI
    component "vitest.config.ts\nVitest" as Vitest
    component "eslint.config.mjs\nESLint" as ESLint
    component "tsconfig.json\nTypeScript" as Tsconfig
    component "next.config.ts\nNext config" as NextConfig
    component "package.json\nScripts/deps" as PackageJson

    component "tests/domain/**\nAggregates / policies / services / VOs" as DomainTests
    component "tests/application/**\nUse cases" as ApplicationTests
    component "tests/lib/**\nAuth / audit / InsForge / read-models" as InfraTests
    component "Faltan tests:\nAPI routes / MCP e2e /\nRLS real / IA routes" as MissingTests #FFEBEE
  }
}

' ============================================================
' BASE DE DATOS / MODELO
' ============================================================

database "InsForge / PostgreSQL\nmigrations/**" as Database #FFF8E1 {

  entity "users" as TUsers {
    * id : uuid <<PK>>
    --
    full_name : text
    email : text <<unique>>
    password_hash : text
    system_role : smallint
    account_origin : smallint
    created_on_utc : timestamptz
    updated_on_utc : timestamptz
  }

  entity "projects" as TProjects {
    * id : uuid <<PK>>
    --
    name : text
    description : text
    external_reference : text
    owner_id : uuid <<FK users.id>>
    created_on_utc : timestamptz
    updated_on_utc : timestamptz
  }

  entity "project_members" as TProjectMembers {
    * project_id : uuid <<PK, FK projects.id>>
    * user_id : uuid <<PK, FK users.id>>
    --
    role : smallint
    joined_on_utc : timestamptz
  }

  entity "user_stories" as TUserStories {
    * id : uuid <<PK>>
    --
    project_id : uuid <<FK projects.id>>
    title : text
    description : text
    created_on_utc : timestamptz
    updated_on_utc : timestamptz
  }

  entity "sprint_tasks" as TSprintTasks {
    * id : uuid <<PK>>
    --
    project_id : uuid <<FK projects.id>>
    user_story_id : uuid <<FK user_stories.id>>
    title : text
    description : text
    is_completed : boolean
    status : text
    created_on_utc : timestamptz
    updated_on_utc : timestamptz
  }

  entity "sprint_task_assignments" as TTaskAssignments {
    * task_id : uuid <<PK, FK sprint_tasks.id>>
    * user_id : uuid <<PK, FK users.id>>
  }

  entity "task_comments" as TTaskComments {
    * id : uuid <<PK>>
    --
    task_id : uuid <<FK sprint_tasks.id>>
    author_id : uuid <<FK users.id>>
    body : text
    created_on_utc : timestamptz
  }

  entity "retained_task_comments" as TRetainedComments {
    * comment_id : uuid <<PK>>
    --
    task_id : uuid
    author_id : uuid <<FK users.id>>
    body : text
    created_on_utc : timestamptz
    retained_on_utc : timestamptz
    retained_by : uuid <<FK users.id nullable>>
    reason : text
  }

  entity "audit_events" as TAuditEvents {
    * id : uuid <<PK>>
    --
    actor_id : uuid <<FK users.id nullable>>
    action : text
    entity_type : text
    entity_id : uuid
    occurred_on_utc : timestamptz
    metadata : jsonb
  }

  entity "project_keys" as TProjectKeys {
    * id : uuid <<PK>>
    --
    project_id : uuid <<FK projects.id>>
    key_hash : text <<unique>>
    description : text
    is_active : boolean
    created_on_utc : timestamptz
  }

  entity "task_agent_notes" as TTaskAgentNotes {
    * id : uuid <<PK>>
    --
    project_id : uuid <<FK projects.id>>
    task_id : uuid <<FK sprint_tasks.id>>
    content : text
    created_on_utc : timestamptz
  }

  entity "RLS Policies" as RlsPolicies #FFF3CD {
    projects_select
    user_stories_select
    sprint_tasks_select
    project_members_select
    task_comments_select
    task_agent_notes_select
    audit_events_select
    --
    Riesgo actual:
    algunas lecturas usan
    request_user_id() IS NOT NULL
    en vez de membresía real
  }

  entity "DB Constraints pendientes" as MissingConstraints #FFEBEE {
    Falta constraint compuesto:
    sprint_tasks(project_id, user_story_id)
    debe garantizar misma historia/proyecto
    --
    Falta constraint compuesto:
    task_agent_notes(project_id, task_id)
    debe garantizar misma tarea/proyecto
  }
}

