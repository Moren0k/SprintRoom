TProjects ||--o{ TProjectKeys : project_id
TProjects ||--o{ TTaskAgentNotes : project_id
TSprintTasks ||--o{ TTaskAgentNotes : task_id

RlsPolicies .. TProjects
RlsPolicies .. TUserStories
