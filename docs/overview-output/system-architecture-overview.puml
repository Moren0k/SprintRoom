package "Infraestructura / Lib" as infra {
  package "Auth" {
    [request-auth.ts\nresolveRequestSessionFromRequest()\ngetAccessTokenFromRequest()] as auth_request
    [password-hasher.ts\nPbkdf2PasswordHasher] as auth_hasher
    [oauth-actions.ts\n\"use server\"\ninitiateOAuth(provider)] as auth_action
    [insforge-cookies.ts\nsession cookies helpers] as auth_cookies
    [insforge-server.ts\ncreateInsForgeServerClient()] as auth_server_client
    [session-token.ts] as auth_token
  }

  package "Audit & time" {
    [audit-logger.ts\nInsForgeAuditLogger.record()] as infra_audit
    [system-clock.ts\nSystemClock.utcNow] as infra_clock
    [env.ts\nreadSprintRoomEnv()] as infra_env
  }

  package "InsForge adapters" {
    [client.ts\ncreateSprintRoomInsForgeClient()\ncreateInsForgeDatabaseGateway()] as if_client
    [database-gateway.ts\nSdkInsForgeDatabaseGateway\nselect/insert/upsert/delete] as if_gateway
    [repositories.ts\nInsForge*Repository] as if_repos
    [unit-of-work.ts\nInsForgeUnitOfWork\nNO real DB transaction] as if_uow
    [mappers.ts\nrows <-> domain] as if_mappers
    [schema.ts\nRow types + enum mapping] as if_schema
    [errors.ts\nPersistenceError] as if_errors
  }

  package "Read models" {
    [dashboard.ts\nInsForgeDashboardReadModel] as read_dashboard
  }
}

package "MCP real del sistema" as mcp {
  package "Backend HTTP MCP" {
    [src/lib/mcp/tools.ts\nMCP_TOOL_DEFINITIONS\nparseToolArgs()] as mcp_tools
    [src/lib/mcp/types.ts\nMcp* types] as mcp_types
    [src/lib/mcp/auth.ts\nresolveProjectKey()\nhashProjectKey()] as mcp_auth
    [src/lib/mcp/service.ts\nMcpService\nget/search/update/note/skill] as mcp_service
    [src/lib/mcp/skill.ts\ngetSprintroomMcpSkillPackage()] as mcp_skill
  }

  package "Internal stdio MCP server" {
    [scripts/mcp-server.ts] as mcp_stdio
  }

  package "Public MCP package" {
    [packages/sprintroom-mcp/src/index.ts\nCLI MCP proxy -> /api/mcp] as mcp_pkg
  }
}

database "InsForge / PostgreSQL schema" as db {
  entity "users\n- id PK\n- email UNIQUE\n- password_hash\n- system_role\n- account_origin\n- created_on_utc\n- updated_on_utc" as tbl_users
  entity "projects\n- id PK\n- owner_id FK users\n- name\n- description\n- external_reference\n- created_on_utc\n- updated_on_utc" as tbl_projects
  entity "project_members\n- PK(project_id,user_id)\n- role\n- joined_on_utc" as tbl_members
  entity "user_stories\n- id PK\n- project_id FK\n- title\n- description\n- created_on_utc\n- updated_on_utc" as tbl_stories
  entity "sprint_tasks\n- id PK\n- project_id FK\n- user_story_id FK\n- title\n- description\n- status\n- is_completed\n- created_on_utc\n- updated_on_utc" as tbl_tasks
  entity "sprint_task_assignments\n- PK(task_id,user_id)" as tbl_assignments
  entity "task_comments\n- id PK\n- task_id FK\n- author_id FK\n- body\n- created_on_utc" as tbl_comments
  entity "audit_events\n- id PK\n- actor_id FK nullable\n- action\n- entity_type\n- entity_id\n- occurred_on_utc\n- metadata jsonb" as tbl_audit
  entity "retained_task_comments\n- comment_id PK\n- task_id\n- retained_by\n- reason" as tbl_retained_comments
  entity "project_keys\n- id PK\n- project_id FK\n- key_hash UNIQUE\n- description\n- is_active\n- created_on_utc" as tbl_project_keys
  entity "task_agent_notes\n- id PK\n- project_id FK\n- task_id FK\n- content\n- created_on_utc" as tbl_agent_notes
}

package "RLS / security migrations" as security_pkg {
