@startuml SprintRoom_Arquitectura_Completa
title SprintRoom - Arquitectura completa del repositorio

skinparam shadowing false
skinparam wrapWidth 240
skinparam maxMessageSize 240
skinparam packageStyle rectangle
skinparam linetype ortho
skinparam nodesep 45
skinparam ranksep 35
skinparam componentStyle rectangle
skinparam ArrowColor #4b5563
skinparam PackageBorderColor #334155
skinparam PackageBackgroundColor #f8fafc
skinparam ComponentBorderColor #475569
skinparam ComponentBackgroundColor #ffffff
skinparam NoteBackgroundColor #fff7d6
skinparam NoteBorderColor #b45309
skinparam DatabaseBorderColor #1d4ed8
skinparam DatabaseBackgroundColor #eff6ff

legend right
  == Objetivo ==
  Este diagrama resume el sistema real del repositorio:
  - UI y App Router Next.js
  - API routes
  - Application layer / casos de uso
  - Dominio
  - Infraestructura InsForge
  - MCP interno, HTTP y paquete publico
  - AI endpoints
  - Persistencia SQL
  - Tests y documentos clave

  == Convenciones ==
  Azul: persistencia / base de datos
  Amarillo: notas importantes o riesgos
  Flechas continuas: dependencia o flujo principal
  Flechas punteadas: soporte, docs o pruebas
endlegend

package "Presentacion / Next.js App Router" as presentation {
  package "Paginas app/(app)" as pages_app {
    [dashboard page\napp/(app)/dashboard/page.tsx] as page_dashboard
    [projects page\napp/(app)/projects/page.tsx] as page_projects
    [project detail page\napp/(app)/projects/{projectId}/page.tsx] as page_project_detail
    [story board page\napp/(app)/projects/{projectId}/stories/{userStoryId}/page.tsx] as page_story_board
    [tasks page\napp/(app)/tasks/page.tsx] as page_tasks
    [account page\napp/(app)/account/page.tsx] as page_account
    [docs page\napp/(app)/docs/page.tsx] as page_docs
    [imagine page\napp/(app)/imagine/page.tsx] as page_imagine
  }

  package "Paginas app/(auth)" as pages_auth {
    [login page\napp/(auth)/login/page.tsx] as page_login
    [register page\napp/(auth)/register/page.tsx] as page_register
  }

  package "Componentes cliente" as client_components {
    [projects-client.tsx] as cmp_projects
    [project-detail-client.tsx] as cmp_project_detail
    [story-tasks-client.tsx] as cmp_story_tasks
    [tasks-client.tsx] as cmp_tasks
    [dashboard-client.tsx] as cmp_dashboard
    [account-client.tsx] as cmp_account
    [docs-client.tsx] as cmp_docs
    [auth-forms.tsx] as cmp_auth
    [imagine-client.tsx] as cmp_imagine
    [chatbot.tsx] as cmp_chatbot
    [ui.tsx\nshared UI primitives] as cmp_ui
  }

  component "src/frontend/api-client.ts\napiRequest()\nApiClientError\ngetErrorMessage()" as frontend_api
  component "src/frontend/session-context.tsx\nSessionProvider / useSession" as frontend_session
  component "src/frontend/types.ts\nTipos UI duplicados desde DTOs" as frontend_types
}

package "HTTP API / Next.js Routes" as routes {
  package "Auth routes" {
    [POST /api/auth/register] as route_auth_register
    [POST /api/auth/login] as route_auth_login
    [POST /api/auth/logout] as route_auth_logout
    [GET /api/auth/callback] as route_auth_callback
  }

  package "Account / Admin" {
    [GET,PATCH /api/account] as route_account
    [POST /api/admin/users] as route_admin_users
  }

  package "Project routes" {
    [GET,POST /api/projects] as route_projects
    [GET,PATCH,DELETE /api/projects/{projectId}] as route_project_detail
    [POST /api/projects/{projectId}/members] as route_project_members
    [GET,DELETE /api/projects/{projectId}/members/{userId}] as route_project_member_detail
    [GET,POST /api/projects/{projectId}/user-stories] as route_project_stories
  }

  package "Task & story routes" {
    [GET,POST /api/tasks] as route_tasks
    [GET,PATCH,DELETE /api/tasks/{taskId}] as route_task_detail
    [POST /api/tasks/{taskId}/comments] as route_task_comments
    [GET,DELETE /api/user-stories/{userStoryId}] as route_story_detail
  }

  package "MCP key routes\nbypass parcial del application layer" {
    [GET,POST /api/projects/{projectId}/mcp-keys] as route_mcp_keys
    [PATCH,DELETE /api/projects/{projectId}/mcp-keys/{keyId}] as route_mcp_key_detail
  }

  package "MCP endpoint" {
    [GET,POST /api/mcp] as route_mcp
  }

  package "AI / Assistive endpoints" {
    [POST /api/chat] as route_chat
    [POST /api/imagine/chat] as route_imagine_chat
    [POST /api/imagine/compile] as route_imagine_compile
    [POST /api/imagine/plan] as route_imagine_plan
  }
}

package "Server composition / transport helpers" as server {
  component "src/server/application-scope.ts\ncreateApplicationScope()\ncreateAuthenticatedApplicationScope()" as server_scope
  component "src/server/http.ts\nok()\ncreated()\nnoContent()\nreadJsonObject()\nhandleRouteError()" as server_http
  component "src/server/validation.ts\nrequireString()\nrequireUuid()\nparseProjectRole()\nparseSystemRole()" as server_validation
}

