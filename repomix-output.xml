}`;
}

function buildClaudeDesktopConfigRaw(origin: string, rawKey: string): string {
  return `{
  "mcpServers": {
    "sprintroom": {
      "command": "npx",
      "args": ["-y", "@sprintroom/mcp"],
      "env": {
        "SPRINTROOM_API_URL": "${origin}",
