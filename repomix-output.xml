  0%, 100% { transform: translateY(0); opacity: 0.6; }
  50% { transform: translateY(6px); opacity: 1; }
}

@keyframes fade-up {
  from { opacity: 0; transform: translateY(12px); }
  to { opacity: 1; transform: translateY(0); }
}

.orb-float-1 { animation: float-slow 12s ease-in-out infinite; }
.orb-float-2 { animation: float-slower 16s ease-in-out infinite; }
.arrow-bounce { animation: bounce-soft 1.8s ease-in-out infinite; }
.fade-up { animation: fade-up 0.9s ease-out both; }
.fade-up-delay-1 { animation: fade-up 0.9s ease-out 0.15s both; }
.fade-up-delay-2 { animation: fade-up 0.9s ease-out 0.30s both; }
.fade-up-delay-3 { animation: fade-up 0.9s ease-out 0.45s both; }

@media (prefers-reduced-motion: reduce) {
  .orb-float-1,
  .orb-float-2,
  .arrow-bounce,
  .fade-up,
  .fade-up-delay-1,
  .fade-up-delay-2,
  .fade-up-delay-3 {
    animation: none;
  }
}

/* Scrollbar global — estilo Apple */
::-webkit-scrollbar {
  width: 5px;
  height: 5px;
}

::-webkit-scrollbar-track {
  background: transparent;
}

::-webkit-scrollbar-thumb {
  background: var(--scrollbar);
  border-radius: 999px;
  transition: background 0.2s;
}

::-webkit-scrollbar-thumb:hover {
  background: var(--scrollbar-hover);
}

* {
  scrollbar-width: thin;
  scrollbar-color: var(--scrollbar) transparent;
}
